{
	"name": "valdrics-frontend",
	"private": true,
	"version": "0.0.1",
	"packageManager": "pnpm@10.32.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 5174",
		"build": "svelte-kit sync && vite build",
		"preview": "node scripts/sync-preview-static-assets.mjs && vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:bundle": "node scripts/check-bundle-size.mjs",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"test:a11y:public": "PLAYWRIGHT_PUBLIC_ONLY=1 playwright test e2e/public-a11y.spec.ts",
		"test:perf": "playwright test e2e/performance.spec.ts",
		"test:perf:ci": "PLAYWRIGHT_PUBLIC_ONLY=1 playwright test e2e/performance.spec.ts",
		"test:visual": "PLAYWRIGHT_PUBLIC_ONLY=1 playwright test e2e/landing-visual.spec.ts",
		"test:visual:update": "PLAYWRIGHT_PUBLIC_ONLY=1 playwright test e2e/landing-visual.spec.ts --update-snapshots",
		"audit:deps": "node scripts/audit-deps.mjs",
		"audit:deps:strict": "node scripts/audit-deps.mjs high",
		"knip": "knip",
		"depcruise": "depcruise src --config .dependency-cruiser.cjs",
		"depcruise:html": "depcruise src --config .dependency-cruiser.cjs --output-type html --output-path ../dependency-graph.html"
	},
	"devDependencies": {
		"@playwright/test": "1.61.1",
		"@sveltejs/adapter-cloudflare": "7.2.9",
		"@sveltejs/vite-plugin-svelte": "7.1.2",
		"@tailwindcss/vite": "4.3.1",
		"@testing-library/svelte": "5.4.2",
		"@types/node": "26.0.1",
		"@vitest/browser-playwright": "4.1.9",
		"axe-playwright": "2.2.2",
		"dependency-cruiser": "^18.0.0",
		"jsdom": "29.1.1",
		"knip": "^6.22.0",
		"playwright": "1.61.1",
		"prettier": "3.9.1",
		"prettier-plugin-svelte": "4.1.1",
		"svelte-check": "4.7.1",
		"typescript": "6.0.3",
		"vite": "8.1.0",
		"vitest": "4.1.9",
		"wrangler": "4.105.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp",
			"workerd"
		],
		"overrides": {
			"cookie": "0.7.2",
			"devalue@<5.8.1": "5.8.1",
			"svelte@<5.51.5": ">=5.51.5",
			"@sveltejs/kit@<2.57.1": ">=2.57.1",
			"junit-report-builder": "5.1.2",
			"minimatch@<10.2.1": ">=10.2.1",
			"picomatch@<4.0.4": ">=4.0.4",
			"rollup@<4.59.0": ">=4.59.0",
			"undici": "7.28.0",
			"vite@<7.3.5": ">=7.3.5",
			"ws@<8.21.0": ">=8.21.0"
		}
	},
	"dependencies": {
		"@lucide/svelte": "1.21.0",
		"@supabase/ssr": "0.12.0",
		"@supabase/supabase-js": "2.108.2",
		"@sveltejs/kit": "2.68.0",
		"@tailwindcss/postcss": "4.3.1",
		"clsx": "2.1.1",
		"dompurify": "3.4.11",
		"svelte": "5.56.4",
		"tailwind-merge": "3.6.0",
		"tailwindcss": "4.3.1",
		"zod": "4.4.3"
	}
}
